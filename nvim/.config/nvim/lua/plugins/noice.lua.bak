return {
  "folke/noice.nvim",
  event = "VeryLazy",
  dependencies = {
    "MunifTanjim/nui.nvim",
    "rcarriga/nvim-notify", -- opcional
  },
  opts = {
    lsp = {
      -- override markdown rendering so that cmp and other plugins use Treesitter
      override = {
        ["vim.lsp.util.convert_input_to_markdown_lines"] = true,
        ["vim.lsp.util.stylize_markdown"] = true,
        ["cmp.entry.get_documentation"] = true, -- requires hrsh7th/nvim-cmp
      },
    },
    -- presets para uma configuração mais fácil
    presets = {
      bottom_search = true,         -- usa a barra de pesquisa clássica na parte inferior
      command_palette = true,       -- posiciona a linha de comando e o popupmenu juntos no centro
      long_message_to_split = true, -- mensagens longas serão enviadas para um split
      inc_rename = true,            -- <-- MODIFICADO: Agora está ativado por padrão aqui
      lsp_doc_border = false,       -- borda para hover docs e signature help
    },
  },
}
