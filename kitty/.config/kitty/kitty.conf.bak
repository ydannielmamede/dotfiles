
cursor_trail 5
cursor_trail_decay 0.04 0.12
cursor_trail_start_threshold 0
cursor_shape block
cursor_blink_interval 0

repaint_delay 5
input_delay 1
sync_to_monitor yes

# BEGIN_KITTY_THEME
# Noctalia
include current-theme.conf
# END_KITTY_THEME

#: Fonts {{{

#: kitty has very powerful font management. You can configure
#: individual font faces and even specify special fonts for particular
#: characters.
# font_family SF Compact Text Medium


# font_family      family='SF Mono' 
# bold_font        auto
# italic_font      auto
# bold_italic_font auto

font_size 16.5
 confirm_os_window_close 0
background_opacity 0.7

# BEGIN_KITTY_FONTS
font_family      family="JetBrainsMonoNL Nerd Font Mono"
bold_font        auto
italic_font      auto
bold_italic_font auto
# END_KITTY_FONTS
